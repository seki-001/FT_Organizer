# App
NODE_ENV=development
# Set to your stable Vercel staging URL (dev branch deploy)
NEXT_PUBLIC_SITE_URL=https://ft-organizer.vercel.app

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32

# Observability (optional in local dev)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Email (Resend — auth emails via Supabase SMTP)
# Get from: https://resend.com → API Keys
# Until organizer.co.ke is verified in Resend, use onboarding@resend.dev (test sends only to your Resend account email)
RESEND_API_KEY=
AUTH_SMTP_FROM_EMAIL=onboarding@resend.dev

# Payments — M-Pesa Daraja (Safaricom)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_MODE=paybill
MPESA_CALLBACK_URL=
NEXT_PUBLIC_MPESA_PAYBILL=174379
NEXT_PUBLIC_MPESA_TILL=
NEXT_PUBLIC_MPESA_ACCOUNT_NAME=Faith The Organizer
NEXT_PUBLIC_MPESA_MODE=paybill

# Payments — Paystack
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Payments — Flutterwave (legacy, optional)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth — enable Google provider in dashboard; add redirect URL /auth/callback
