# ─────────────────────────────────────────────────────────────────────────────
# Faith The Organizer — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it contains secrets.
# This file (.env.local.example) IS committed as documentation.
# ─────────────────────────────────────────────────────────────────────────────


# ── M-Pesa / IntaSend ─────────────────────────────────────────────────────────
# Get from: https://console.intasend.com → Settings → API Keys
# Use IntaSend as the Daraja API wrapper for M-Pesa STK Push.
INTASEND_API_KEY=your_key_here
INTASEND_SECRET_KEY=your_secret_here

# Set to "true" for sandbox testing, "false" for production
INTASEND_IS_SANDBOX=true

# Direct Daraja (optional — if using Daraja directly instead of IntaSend)
# Get from: https://developer.safaricom.co.ke → My Apps
# DARAJA_CONSUMER_KEY=your_key_here
# DARAJA_CONSUMER_SECRET=your_secret_here
# DARAJA_BUSINESS_SHORT_CODE=174379
# DARAJA_PASSKEY=your_passkey_here
# DARAJA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback


# ── Flutterwave ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.flutterwave.com → Settings → API Keys
# Use test keys (FLWPUBK_TEST-... / FLWSECK_TEST-...) for development.
FLUTTERWAVE_PUBLIC_KEY=your_key_here
FLUTTERWAVE_SECRET_KEY=your_secret_here


# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
# Required for all NextAuth.js authentication to work.
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# The full URL of your site (no trailing slash)
# Use http://localhost:3000 for local development
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — Get from: https://console.cloud.google.com
#   1. Create a new project (or use existing)
#   2. Enable "Google+ API" or "Google Identity"
#   3. Credentials → Create OAuth 2.0 Client ID
#   4. Authorised redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret


# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys → Create API Key
# Used for: booking confirmations, order receipts, contact form replies,
#           newsletter welcome emails.
RESEND_API_KEY=your_key_here

# The "from" email domain (must be verified in Resend dashboard)
# RESEND_FROM_EMAIL=noreply@organizer.co.ke


# ── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com → Admin → Data Streams → Web stream
# Prefix NEXT_PUBLIC_ makes this available in the browser bundle.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ── Site URL ──────────────────────────────────────────────────────────────────
# The canonical production URL of the site.
# Used for: OG tags, sitemaps, absolute URLs in emails.
NEXT_PUBLIC_SITE_URL=https://www.organizer.co.ke
